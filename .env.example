# Supabase — public (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — server only. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public site URL — used to build the staff invite redirect link
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Platform admin — server only. Comma-separated emails of the TrustOps operator(s)
# who can access /admin and the Help Center support inbox. Leave blank to lock
# everyone out of the admin area. Match the email you log in with, exactly.
PLATFORM_ADMIN_EMAILS=you@example.com
# Optional: comma-separated WhatsApp numbers (E.164, e.g. 2349134062773) that get
# a copy of each Help Center report. Requires WHATSAPP_TOKEN/WHATSAPP_PHONE_ID
# (and an approved template) to actually send; otherwise it's a no-op simulated send.
PLATFORM_ADMIN_WHATSAPP=
# Approved WhatsApp template for the cold operator alert. Create a template in
# Meta WhatsApp Manager (category: UTILITY) whose BODY has exactly three
# placeholders in order: {{1}} = reporter (and company), {{2}} = subject,
# {{3}} = message. Put its name here. Leave blank to send free-form text
# instead (only delivered inside a 24h customer-service window).
# Example body: "New support report from {{1}}. Subject: {{2}}. Message: {{3}}"
PLATFORM_ADMIN_WHATSAPP_TEMPLATE=
# Template language code as registered in Meta (default "en"). Often "en_US".
PLATFORM_ADMIN_WHATSAPP_TEMPLATE_LANG=en

# AI assistant (Phase 6) — server only. NEVER expose to the client.
# Without ANTHROPIC_API_KEY the assistant stays disabled (no live calls), the
# rest of the app is unaffected. AI_MODEL is optional (defaults to claude-opus-4-8).
ANTHROPIC_API_KEY=your-anthropic-api-key
AI_MODEL=claude-opus-4-8

# Messaging (Phase 4) — optional. Leave blank to run in simulated (no-op) mode.
# Email via Resend:
RESEND_API_KEY=your-resend-api-key
EMAIL_FROM=TrustOps <noreply@yourdomain.com>
# WhatsApp Business Cloud API (Meta):
WHATSAPP_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_ID=your-whatsapp-phone-number-id

# Vercel Cron — protects /api/cron (the serverless background-jobs tick).
# Set this in the Vercel dashboard; Vercel sends it as a Bearer token on cron
# invocations. Generate with: openssl rand -hex 32
CRON_SECRET=your-long-random-secret

# Local RLS test harness (scripts/rls-test.ts) — Dockerized Postgres
RLS_TEST_DATABASE_URL=postgres://postgres:postgres@localhost:55432/postgres
